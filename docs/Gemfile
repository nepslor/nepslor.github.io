# frozen_string_literal: true

# GitHub Pages builds with Ruby 3.3.x. github-pages 232 pulls in commonmarker, which
# requires Ruby < 4.0 — Homebrew Ruby 4 cannot resolve this stack. Use Ruby 3.3 locally:
#   brew install ruby@3.3
#   echo 'export PATH="/opt/homebrew/opt/ruby@3.3/bin:$PATH"' >> ~/.zshrc
# Or: rbenv install 3.3.6 && rbenv local 3.3.6
ruby "~> 3.3"

source "https://rubygems.org"

# Same dependency set as production: https://pages.github.com/versions/
# Always: bundle exec jekyll serve   (not a global `jekyll` binary)
# https://docs.github.com/pages/setting-up-a-github-pages-site-with-jekyll
gem "github-pages", "232", group: :jekyll_plugins

# Ruby 3.0+ — Webrick is not in the default gems; needed for `jekyll serve`.
gem "webrick", "~> 1.8"

# Silences Liquid’s “bigdecimal will not be a default gem in Ruby 3.4+” warning on Ruby 3.3.
gem "bigdecimal"

# Windows / JRuby — zoneinfo
platforms :windows, :jruby do
  gem "tzinfo", "~> 1.2"
  gem "tzinfo-data"
end

gem "wdm", "~> 0.1.1", platforms: [:windows]
